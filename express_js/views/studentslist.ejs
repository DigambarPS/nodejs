<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student List</title>
</head>
<body>
    <h1>Student List</h1>
    <table>
        <tr>
            <th>Name</th>
            <th>Age</th>
            <th>Email</th>
        </tr>
        <% data.forEach(e =>{ %>
           <tr>
            <td><%= e.name %></td>
            <td><%=e.age %></td>
            <td><%=e.email %></td>
            </tr> 
        <%  })%>  
    </table>
</body>
</html>